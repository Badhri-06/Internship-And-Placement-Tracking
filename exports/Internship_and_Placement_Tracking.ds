		workflow
		{
		form
		{
			Auto_Update_Placement_Sta as "Auto Update Placement Status"
			{
				type =  form
				form = internship_applications

				record event = on edit

				on success
				{
					actions  (status == "Accepted")
					{
					update students[Placement_Status == "placed"]
					[
						Placement_Status = "placed"
					]
					}
				}

			}
		}

		schedule
		{
			Interview_Reminder_Email as "Interview Reminder Email"
			{
				type =  schedule
				form = internship_applications[status == "Interview"]
				start = before 1 days from interview_date at "15:00:00"
				time zone = "America/Los_Angeles"
				on start
				{
				}
			}
		}


		blueprint
		{
    			deadline_reminder_system as "Deadline Reminder System"
    			{
        			type = Blueprint
