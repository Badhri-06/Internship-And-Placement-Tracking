				width = medium
			)
			graduation_year
			(
				type = number
				displayname = "Graduation Year"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			resume_link
			(
    			type = url
				displayname = "Resume Link"
	 			row = 1
	 			column = 1   
				width = medium
			)
			created_at
			(
    			type = datetime
				displayname = "Created At"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			updated_at
			(
    			type = datetime
				displayname = "Updated At"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			Placement_Status
			(
				type = picklist
				displayname = "Placement Status"
				maxchar = 100
				values = {"Not Placed","placed"}
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
	}
	reports
	{
		list internship_applications_Report
		{
			displayName = "All Internship Applications"
			show all rows from internship_applications    
			(
				application_id as "Application ID"
				student as "Student"
				company as "Company"
				job_title as "Job Title"
				application_date as "Application Date"
				status as "Status"
				offer_letter as "Offer Letter"
				interview_date as "Interview Date"
				notes as "Notes"
				created_at as "Created At"
				updated_at as "Updated At"
			)
		}
		kanban internship_applications_by_status
		{
			displayName = "Statuses"
			show all rows from internship_applications    
			(
				application_id as "Application ID"
				student as "Student"
				company as "Company"
				job_title as "Job Title"
				application_date as "Application Date"
				status as "Status"
				offer_letter as "Offer Letter"
				interview_date as "Interview Date"
				notes as "Notes"
				created_at as "Created At"
				updated_at as "Updated At"
			)
			options
			(
	 			display field = status
	 		)
		}
		list placement_visits_Report
		{
			displayName = "All Placement Visits"
			show all rows from placement_visits    
			(
				company as "Company"
				visit_date as "Visit Date"
				visit_type as "Visit Type"
				contact_person as "Contact Person"
				contact_email as "Contact Email"
				contact_phone as "Contact Phone"
				schedule_notes as "Schedule Notes"
				status as "Status"
				created_at as "Created At"
				updated_at as "Updated At"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (visit_type == "Campus Drive")
				fields = [visit_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (visit_type == "On-Campus Interview")
				fields = [visit_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (visit_type == "Virtual Meet")
				fields = [visit_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
				"New Formatting4"
				{
				condition = (visit_type == "Workshop")
				fields = [visit_type]
				format = "color:#ffffff;background-color:#3598db;"
				}
			)
		}
		kanban placement_visits_by_visit_type
		{
			displayName = "Visit Types"
			show all rows from placement_visits    
			(
				company as "Company"
				visit_date as "Visit Date"
				visit_type as "Visit Type"
				contact_person as "Contact Person"
				contact_email as "Contact Email"
				contact_phone as "Contact Phone"
				schedule_notes as "Schedule Notes"
				status as "Status"
				created_at as "Created At"
				updated_at as "Updated At"
			)
			options
			(
	 			display field = visit_type
	 		)
		}
		list deadlines_Report
		{
			displayName = "All Deadlines"
			show all rows from deadlines    
			(
				deadline_id as "Deadline ID"
				application as "Application"
				deadline_date as "Deadline Date"
				reminder_sent as "Reminder Sent"
				reminder_sent_at as "Reminder Sent At"
				description as "Description"
				created_at as "Created At"
				updated_at as "Updated At"
			)
		}
		list email_reminders_Report
		{
			displayName = "All Email Reminders"
			show all rows from email_reminders    
			(
				deadline as "Deadline"
				sent_to as "Sent To"
				sent_at as "Sent At"
				subject_1 as "Subject"
				body as "Body"
				status as "Status"
				created_at as "Created At"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Queued")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Sent")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban email_reminders_by_status
		{
			displayName = "Statuses"
			show all rows from email_reminders    
			(
				deadline as "Deadline"
				sent_to as "Sent To"
				sent_at as "Sent At"
				subject_1 as "Subject"
				body as "Body"
				status as "Status"
				created_at as "Created At"
			)
			options
			(
	 			display field = status
	 		)
		}
		list resume_search_Report
		{
			displayName = "All Searches"
			show all rows from resume_search    
			(
				student as "Student"
				skills as "Skills"
				experience_years as "Experience Years"
				highest_qualification as "Highest Qualification"
				graduation_year as "Graduation Year"
				created_at as "Created At"
				updated_at as "Updated At"
			)
		}
		list students_Report
		{
			displayName = "All Students"
			show all rows from students    
			(
				student_id as "Student ID"
				first_name1 as "First Name"
				last_name1 as "Last Name"
				email as "Email"
				phone as "Phone"
				major as "Major"
				graduation_year as "Graduation Year"
				resume_link as "Resume Link"
				created_at as "Created At"
				updated_at as "Updated At"
			)
		}
		list placement_reports_Report
		{
			displayName = "All Placement Reports"
			show all rows from placement_reports    
			(
				program as "Program"
				total_applicants as "Total Applicants"
				interviews_held as "Interviews Held"
				offers_made as "Offers Made"
				placement_rate as "Placement Rate"
				(
					display = total,average,min,max	
				)
				year_1 as "Year"
				created_at as "Created At"
				updated_at as "Updated At"
			)
		}
		list companies_Report
		{
			displayName = "All Companies"
			show all rows from companies    
			(
				company_id as "Company ID"
				company_name as "Company Name"
				industry as "Industry"
				website as "Website"
				contact_person as "Contact Person"
				contact_email as "Contact Email"
				contact_phone as "Contact Phone"
				address  as "Address"
	 			(
	      			displayformat = [address_line_1+""+address_line_2+""+district_city+""+state_province+""+postal_Code+""+country]
	      			enable = Link_to_Map,Show_As_Text
	 			)
				created_at as "Created At"
				updated_at as "Updated At"
			)
		}
	}
	pages
	{
		page DashBoard
		{
			displayname = "Dashboard"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='25%'\n   \t>\n\t<panel elementName='Panel 1'\n \n >\n\t<pr \n\t\t\twidth='fill'\n\t\theight='fill'\n>\n\t<pc \n\t\tpadding = '0px'\n\tbgColor = '#F97164'\n\n\t\twidth = '100%'\n\t\thAlign = 'left'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='fill'\n\t\theight='fill'\n>\n\t<pc \n\t\tpaddingTop = '20px'\n\tpaddingLeft = '20px'\n\tpaddingRight = '0px'\n\tpaddingBottom = '20px'\n\tbgColor = 'rgba(0, 0, 0, 0)'\n\n\t\twidth = '64%'\n\t\thAlign = 'left'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='auto'\n\t\theight='auto'\n>\n\t<pc \n\t\n>\n\t<pr \n\t>\n\t<pc \n\t\n>\n\t<text \n\n\tmarginLeft = '0px'\n\tmarginRight = '0px' \n\tmarginTop = '8px'\n\tcolor = '#FFFFFF'\n\tsize = '24px'\n\tbold = 'true' \n\ttype = 'Form Data'\n\n\tbgColor = 'rgba(0, 0, 0, 0)'\n\n\n\tdisplayType = 'actual'\n\tdecimalPlaces = '2'\n\tthousandsSeperator = 'LOCALE'\n\tdecimalSeperator = 'DOT'\n\tnumberScale = 'none'\n\n\n\n\n\t  value = 'thisapp.placement_reports.total_applicants.sum'\n>\n</text>\n\n</pc>\n</pr><pr \n\t>\n\t<pc \n\t\n>\n\t<text \n\n\tmarginLeft = '0px'\n\tmarginRight = '8px' \n\tmarginTop = '0px'\n\tcolor = '#FFFFFF'\n\tsize = '14px'\n\ttype = 'Text'\n\n\tbgColor = 'rgba(0, 0, 0, 0)'\n\n\n\n\n\n\n\t  value = 'Total Total Applicants'\n>\n</text>\n\n</pc>\n</pr>\n</pc>\n</pr>\n</pc><pc \n\t\tpadding = '20px'\n\tbgColor = 'rgba(0, 0, 0, 0)'\n\n\t\twidth = '36%'\n\t\thAlign = 'right'\n\t\tvAlign = 'middle'\n>\n\t<pr \n\t\t\twidth='auto'\n\t\theight='auto'\n>\n\t<pc \n\t\n>\n\t<image  \n\t\tmarginLeft = '10px'\n\tmarginRight = '0px' \n\tmarginBottom = '0px'\n\tmarginTop = '0px'\n\n\tcolor = '#FFFFFF'\n\tbgColor = '#C75A50'\n\twidth = '40px'\n\theight = '40px'\n\ttype = 'icon'\n\tvalue = 'business-percentage-39'\n\tsize = '22px'\n\tcornerRadius = '10px'\n\ticonType = 'outline'\n/>\n</pc>\n</pr>\n</pc>\n</pr>\n</pc>\n</pr>\n</panel>\n</column><column\n   \t\t width='24%'\n   \t>\n\t<pa